<!-- ===== Auth ===== -->
<main class="auth-wrap">
    <div class="auth-card" data-aos="fade-up">

        <!-- Login form -->
        <div id="loginPane">
            <h2>Welcome back</h2>
            <p class="auth-sub">Sign in to view your collections.</p>

            <form onsubmit="event.preventDefault(); window.location.href='dashboard.html';">
                <div class="mb-3">
                    <label for="loginEmail" class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control" id="loginEmail" placeholder="you@example.com" required>
                    </div>
                </div>

                <div class="mb-2">
                    <label for="loginPassword" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control" id="loginPassword" placeholder="At Least 8 Characters" required>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember">
                        <label class="form-check-label text-muted-2 small" for="remember">Remember me</label>
                    </div>
                    <a href="#" class="small">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-gold w-100"><i class="bi bi-box-arrow-in-right me-1"></i> Sign in</button>
            </form>

            <div class="divider">or continue with</div>
            <div class="d-grid gap-2">
                <button type="button" class="social-btn"><i class="bi bi-google"></i> Continue with Google</button>
                <button type="button" class="social-btn"><i class="bi bi-microsoft"></i> Continue with Microsoft</button>
                <button type="button" class="social-btn"><i class="bi bi-apple"></i> Continue with Apple</button>
            </div>

            <p class="text-center text-muted-2 small mt-4 mb-0">
                New to Collectify?
                <a href="#" data-toggle-auth="signup" class="fw-500">Create an account</a>
            </p>
        </div>

        <!-- Signup form (hidden by default) -->
        <div id="signupPane" hidden>
            <h2>Start your collection</h2>
            <p class="auth-sub">Create a free Collectify account in seconds.</p>

            <form onsubmit="event.preventDefault(); window.location.href='dashboard.html';">
                <div class="row g-2 mb-3">
                    <div class="col-sm-6">
                        <label for="firstName" class="form-label">First name</label>
                        <input type="text" class="form-control" id="firstName" placeholder="Shlok" required>
                    </div>
                    <div class="col-sm-6">
                        <label for="lastName" class="form-label">Last name</label>
                        <input type="text" class="form-control" id="lastName" placeholder="Goud" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="signupEmail" class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control" id="signupEmail" placeholder="you@example.com" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="signupPassword" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control" id="signupPassword" placeholder="At least 8 characters" minlength="8" required>
                    </div>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="terms" required>
                    <label class="form-check-label text-muted-2 small" for="terms">
                        I agree to the <a href="#">Terms</a> and <a href="#">Privacy Policy</a>.
                    </label>
                </div>

                <button type="submit" class="btn btn-gold w-100"><i class="bi bi-person-plus me-1"></i> Create account</button>
            </form>

            <div class="divider">or sign up with</div>
            <div class="d-grid gap-2">
                <button type="button" class="social-btn"><i class="bi bi-google"></i> Sign up with Google</button>
                <button type="button" class="social-btn"><i class="bi bi-microsoft"></i> Sign up with Microsoft</button>
                <button type="button" class="social-btn"><i class="bi bi-apple"></i> Sign up with Apple</button>
            </div>

            <p class="text-center text-muted-2 small mt-4 mb-0">
                Already have an account?
                <a href="#" data-toggle-auth="login" class="fw-500">Sign in</a>
            </p>
        </div>

    </div>
</main>