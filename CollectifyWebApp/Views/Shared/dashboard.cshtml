<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Collectify</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
  <link href="css/styles.css" rel="stylesheet">
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-collectify">
    <div class="container">
      <a class="navbar-brand" href="index.html"><span class="brand-mark"><i class="bi bi-diamond-fill"></i></span>Collectify</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav ms-auto align-items-lg-center">
          <li class="nav-item"><a class="nav-link" href="index.html">Home</a></li>
          <li class="nav-item"><a class="nav-link active" href="dashboard.html">Dashboard</a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Manage</a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="create.html"><i class="bi bi-plus-circle me-2"></i>Add Item</a></li>
              <li><a class="dropdown-item" href="read.html"><i class="bi bi-list-ul me-2"></i>List</a></li>
              <li><a class="dropdown-item" href="update.html"><i class="bi bi-pencil-square me-2"></i>Update</a></li>
              <li><a class="dropdown-item" href="delete.html"><i class="bi bi-trash me-2"></i>Delete</a></li>
            </ul>
          </li>
          <li class="nav-item"><a class="nav-link" href="about.html">About</a></li>
          <li class="nav-item ms-lg-2">
            <a class="btn btn-outline-gold btn-sm px-3" href="login.html"><i class="bi bi-person-circle me-1"></i> Sign in</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="section">
    <div class="container">

      <div class="d-flex flex-wrap align-items-end justify-content-between mb-4" data-aos="fade-up">
        <div>
          <div class="section-label">Overview</div>
          <h1 class="section-title mb-2">Portfolio Dashboard</h1>
          <p class="text-muted-2 mb-0">A live snapshot of your collections, valuations and trends.</p>
        </div>
        <div class="text-muted-2 small mt-3 mt-md-0">
          <i class="bi bi-calendar3 me-1"></i> Last updated: Today
        </div>
      </div>

      <!-- KPI strip -->
      <div class="row g-4 mb-5">
        <div class="col-md-4" data-aos="zoom-in">
          <div class="stat-card">
            <div class="stat-label">Total Collections</div>
            <div class="stat-value">12</div>
            <div class="stat-trend"><i class="bi bi-arrow-up-short text-gold"></i> 2 added this month</div>
          </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="80">
          <div class="stat-card">
            <div class="stat-label">Total Items</div>
            <div class="stat-value">438</div>
            <div class="stat-trend"><i class="bi bi-arrow-up-short text-gold"></i> 17 added this month</div>
          </div>
        </div>
        <div class="col-md-4" data-aos="zoom-in" data-aos-delay="160">
          <div class="stat-card">
            <div class="stat-label">Estimated Portfolio Value</div>
            <div class="stat-value">$24,860</div>
            <div class="stat-trend"><i class="bi bi-arrow-up-short text-gold"></i> +6.4% vs last month</div>
          </div>
        </div>
      </div>

      <!-- Charts -->
      <div class="row g-4">
        <div class="col-lg-5" data-aos="fade-up">
          <div class="chart-card">
            <h5>Portfolio Distribution by Category</h5>
            <div class="chart-canvas-wrap"><canvas id="pieChart"></canvas></div>
          </div>
        </div>
        <div class="col-lg-7" data-aos="fade-up" data-aos-delay="80">
          <div class="chart-card">
            <h5>Top Valuable Items</h5>
            <div class="chart-canvas-wrap"><canvas id="barChart"></canvas></div>
          </div>
        </div>
        <div class="col-12" data-aos="fade-up" data-aos-delay="160">
          <div class="chart-card">
            <h5>Portfolio Value Over Time</h5>
            <div class="chart-canvas-wrap" style="height: 320px;"><canvas id="lineChart"></canvas></div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container d-flex flex-wrap justify-content-between align-items-center">
      <div><span class="brand-mark"><i class="bi bi-diamond-fill"></i></span> <strong>Collectify</strong> &middot; Curate. Value. Treasure.</div>
      <div class="text-muted-2 small">&copy; 2026 Collectify &middot; Prototype</div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
  <script>AOS.init({ duration: 700, easing: 'ease-out-cubic', once: true, offset: 60 });</script>
  <script src="js/charts.js"></script>
  
    <script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
<script src="https://files.bpcontent.cloud/2026/04/20/00/20260420000929-257CPL8Z.js" defer></script>
    
</body>
</html>
