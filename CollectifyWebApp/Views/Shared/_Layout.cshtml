@{
    // Define navigation pages for dynamic rendering
    string[] navPages = { "Home", "Dashboard", "Manage","About", "Sign In" };

    // Define dropdown items for the Manage menu
    // { "Action", "Icon", "Text Label" }
    string[,] dropDownItems = {
        { "create", "bi bi-plus-circle me-2", "Add Item" },
        { "", "bi bi-list-ul me-2", "List" },
        { "edit", "bi bi-pencil-square me-2", "Update" },
        { "delete", "bi bi-trash me-2", "Delete" }
    };

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Collectify | Track every collection, beautifully</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <!-- Theme -->
    <link href="css/styles.css" rel="stylesheet">
</head>
<body>

    <!-- ===== Navbar ===== -->
    <nav class="navbar navbar-expand-lg navbar-collectify">
        <div class="container">
            <a class="navbar-brand" href="/home">
                <span class="brand-mark"><i class="bi bi-diamond-fill"></i></span>Collectify
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    @*Dynamically render navigation items*@
                    @foreach (var pageName in navPages)
                    {
                        bool isActive = string.Equals(pageName, currentController, StringComparison.OrdinalIgnoreCase);

                        if (pageName == "Manage")
                        {
                            @* Fill the Manage List*@
                            string currentClass = isActive ? "nav-link dropdown-toggle active" : "nav-link dropdown-toggle";

                            <li class="nav-item dropdown">
                                <a class="@currentClass" href="#" role="button" data-bs-toggle="dropdown">Manage</a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @for (int i = 0; i < dropDownItems.GetLength(0); i++)
                                    {
                                        bool isActive2 = string.Equals(@dropDownItems[i,0], currentController, StringComparison.OrdinalIgnoreCase);

                                        <li>
                                            <a class="dropdown-item @(isActive2 ? "active" : "")" href="/items/@dropDownItems[i,0]">
                                                <i class="@dropDownItems[i,1]"></i>@dropDownItems[i,2]
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        else if (pageName == "Sign In")
                        {
                            @* Special button style for Sign In *@
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-outline-gold btn-sm px-3 @(currentController == "Login" ? "active" : "")" href="/login">
                                    <i class="bi bi-person-circle me-1"></i> Sign in
                                </a>
                            </li>
                        }
                        else if (pageName == "About")
                        {
                            @* Special button style for About *@
                            <li class="nav-item">
                                <a class="nav-link @(isActive ? "active" : "")" href="/home/about">About</a>
                            </li>
                        }
                        else
                        {
                            @* Standard style for everyone else *@
                            <li class="nav-item">
                                <a class="nav-link @(isActive ? "active" : "")" href="/@pageName.ToLower()">@pageName</a>
                            </li>
                        }
                    }

                    @* <li class="nav-item"><a class="nav-link active" href="home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="dashboard">Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Manage</a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="create"><i class="bi bi-plus-circle me-2"></i>Add Item</a></li>
                            <li><a class="dropdown-item" href="read"><i class="bi bi-list-ul me-2"></i>List</a></li>
                            <li><a class="dropdown-item" href="update"><i class="bi bi-pencil-square me-2"></i>Update</a></li>
                            <li><a class="dropdown-item" href="delete"><i class="bi bi-trash me-2"></i>Delete</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="about">About</a></li>
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-outline-gold btn-sm px-3" href="login">
                            <i class="bi bi-person-circle me-1"></i> Sign in
                        </a>
                    </li> *@
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- ===== Footer ===== -->
    <footer class="site-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <div><span class="brand-mark"><i class="bi bi-diamond-fill"></i></span> <strong>Collectify</strong> &middot; Curate. Value. Treasure.</div>
            <div class="text-muted-2 small">&copy; 2026 Collectify &middot; Prototype</div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 700, easing: 'ease-out-cubic', once: true, offset: 60 });
    </script>
  
    <script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
    <script src="https://files.bpcontent.cloud/2026/04/20/00/20260420000929-257CPL8Z.js" defer></script>
    
</body>
</html>
