@{
    // Define navigation pages for dynamic rendering
    // { "href", "Text Label" }
    string[,] navPages = {
        { "home", "Home" },
        { "dashboard", "Dashboard" },
        { "items", "Manage" },
        { "home/about", "About" }
    };

    // Define dropdown items for the Manage menu
    // { "Action", "Icon", "Text Label" }
    string[,] dropDownItems = {
        { "create", "bi bi-plus-circle me-2", "Add Item" },
        { "", "bi bi-list-ul me-2", "List" },
        { "edit", "bi bi-pencil-square me-2", "Update" },
        { "delete", "bi bi-trash me-2", "Delete" }
    };

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Collectify | Track every collection, beautifully</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <!-- Theme -->
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>

    <!-- ===== Navbar ===== -->
    <nav class="navbar navbar-expand-lg navbar-collectify">
        <div class="container">
            <a class="navbar-brand" href="/home">
                <span class="brand-mark"><i class="bi bi-diamond-fill"></i></span>Collectify
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    @*Dynamically render navigation items*@
                    @for (int i = 0; i < navPages.GetLength(0); i++)
                    {
                        string href = navPages[i, 0].ToLower();
                        string label = navPages[i, 1];

                        string[] hrefSplit = (href + "/").Split('/');
                        string controller = hrefSplit.Length > 0 ? hrefSplit[0] : "home";
                        string action = (hrefSplit.Length > 1 && hrefSplit[1] != "") ? hrefSplit[1] : "index";

                        if (label == "Manage")
                        {
                            // Handle Manage dropdown separately
                            bool isActive = string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase);
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown">Manage</a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @for (int j = 0; j < dropDownItems.GetLength(0); j++)
                                    {
                                        string actionName = dropDownItems[j, 0].ToLower();
                                        string iconClass = dropDownItems[j, 1];
                                        string itemLabel = dropDownItems[j, 2];
                                        bool isActive2 = isActive && string.Equals(actionName, currentAction, StringComparison.OrdinalIgnoreCase);
                                        if (string.Equals(actionName, "", StringComparison.OrdinalIgnoreCase))
                                        {
                                            // Special case of the List button, which goes to the index action
                                            isActive2 = isActive && string.Equals("index", currentAction, StringComparison.OrdinalIgnoreCase);
                                        }
                                        <li>
                                            <a class="dropdown-item @(isActive2 ? "active" : "")" href="/items/@actionName">
                                                <i class="@iconClass"></i> @itemLabel
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        else
                        {
                            // Standard navigation item
                            bool isActive = string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase) && string.Equals(action, currentAction, StringComparison.OrdinalIgnoreCase);
                            <li class="nav-item">
                                <a class="nav-link @(isActive ? "active" : "")" href="/@href">@label</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- ===== Footer ===== -->
    <footer class="site-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <div><span class="brand-mark"><i class="bi bi-diamond-fill"></i></span> <strong>Collectify</strong> &middot; Curate. Value. Treasure.</div>
            <div class="text-muted-2 small">&copy; 2026 Collectify &middot; Prototype</div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 700, easing: 'ease-out-cubic', once: true, offset: 60 });
    </script>
  
    @* <script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script> *@
    @* <script src="https://files.bpcontent.cloud/2026/04/20/00/20260420000929-257CPL8Z.js" defer></script> *@

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="js/charts.js"></script>
    
</body>
</html>
