  <!-- ===== Logical Data Model ===== -->
  <section class="section pt-3">
    <div class="container">
      <div class="text-center mb-4" data-aos="fade-up">
        <div class="section-label">Data Model</div>
        <h2 class="section-title mb-2">How Collectify sees your collections</h2>
        <p class="text-muted-2 mx-auto" style="max-width:620px;">
          Every user owns many collections. Every collection holds many items.
          Each item can track its own price history over time.
        </p>
      </div>

      <!-- Inline SVG ER diagram (replaces /assets/ldm.png) -->
      <div class="card-lux" data-aos="fade-up" data-aos-delay="60">
        <div class="card-body p-3 p-md-4">
          <div class="ldm-wrap" style="width:100%;overflow-x:auto;">
            <svg role="img" aria-labelledby="ldmTitle ldmDesc"
                 viewBox="0 0 1040 360" preserveAspectRatio="xMidYMid meet"
                 style="width:100%;height:auto;min-width:760px;display:block;">
              <title id="ldmTitle">Collectify Logical Data Model</title>
              <desc id="ldmDesc">Four entities connected by one-to-many relationships: User to Collections, Collection to Items, Item to PriceHistory.</desc>

              <defs>
                <!-- arrowhead (crow's foot style simplified) -->
                <marker id="many" viewBox="0 0 14 14" refX="12" refY="7" markerWidth="14" markerHeight="14" orient="auto-start-reverse">
                  <path d="M0 0 L12 7 L0 14 M6 0 L6 14" fill="none" stroke="#D98880" stroke-width="1.6"/>
                </marker>
                <marker id="one" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="12" markerHeight="12" orient="auto-start-reverse">
                  <line x1="2" y1="1" x2="2" y2="11" stroke="#C7A97A" stroke-width="1.6"/>
                  <line x1="6" y1="1" x2="6" y2="11" stroke="#C7A97A" stroke-width="1.6"/>
                </marker>
                <linearGradient id="boxGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#2E2335"/>
                  <stop offset="1" stop-color="#261C2C"/>
                </linearGradient>
              </defs>

              <style>
                .entity { fill: url(#boxGrad); stroke: rgba(199,169,122,0.45); stroke-width: 1.25; }
                .entity-head { fill: rgba(199,169,122,0.12); stroke: rgba(199,169,122,0.35); stroke-width: 1; }
                .entity-title { font: 600 15px 'Playfair Display', serif; fill: #F2EDE4; }
                .field { font: 500 12.5px 'Inter', sans-serif; fill: #F2EDE4; }
                .field-type { font: 400 11.5px 'Inter', sans-serif; fill: #B8ADAE; }
                .key { font: 700 10px 'Inter', sans-serif; letter-spacing: .1em; fill: #C7A97A; }
                .fk  { fill: #D98880; }
                .rel-line { fill: none; stroke: #D98880; stroke-width: 1.6; }
                .rel-label { font: 600 10.5px 'Inter', sans-serif; letter-spacing: .1em; fill: #D98880; }
                .divider  { stroke: rgba(199,169,122,0.2); stroke-width: 1; }
              </style>

              <!-- USER -->
              <g transform="translate(30,90)">
                <rect class="entity" x="0" y="0" width="200" height="180" rx="10"/>
                <rect class="entity-head" x="0" y="0" width="200" height="36" rx="10"/>
                <rect class="entity-head" x="0" y="26" width="200" height="10"/>
                <text class="entity-title" x="100" y="23" text-anchor="middle">User</text>

                <text class="key"       x="14" y="62">PK</text>
                <text class="field"     x="44" y="62">user_id</text>
                <text class="field-type" x="186" y="62" text-anchor="end">UUID</text>
                <line class="divider" x1="10" y1="74" x2="190" y2="74"/>

                <text class="field"     x="14" y="94">name</text>
                <text class="field-type" x="186" y="94" text-anchor="end">VARCHAR</text>

                <text class="field"     x="14" y="120">email</text>
                <text class="field-type" x="186" y="120" text-anchor="end">VARCHAR</text>

                <text class="field"     x="14" y="146">password_hash</text>
                <text class="field-type" x="186" y="146" text-anchor="end">TEXT</text>

                <text class="field"     x="14" y="170">created_at</text>
                <text class="field-type" x="186" y="170" text-anchor="end">TIMESTAMP</text>
              </g>

              <!-- COLLECTION -->
              <g transform="translate(290,90)">
                <rect class="entity" x="0" y="0" width="200" height="180" rx="10"/>
                <rect class="entity-head" x="0" y="0" width="200" height="36" rx="10"/>
                <rect class="entity-head" x="0" y="26" width="200" height="10"/>
                <text class="entity-title" x="100" y="23" text-anchor="middle">Collection</text>

                <text class="key"       x="14" y="62">PK</text>
                <text class="field"     x="44" y="62">collection_id</text>
                <text class="field-type" x="186" y="62" text-anchor="end">UUID</text>
                <line class="divider" x1="10" y1="74" x2="190" y2="74"/>

                <text class="key fk"    x="14" y="94">FK</text>
                <text class="field"     x="44" y="94">user_id</text>
                <text class="field-type" x="186" y="94" text-anchor="end">UUID</text>

                <text class="field"     x="14" y="120">name</text>
                <text class="field-type" x="186" y="120" text-anchor="end">VARCHAR</text>

                <text class="field"     x="14" y="146">category</text>
                <text class="field-type" x="186" y="146" text-anchor="end">ENUM</text>

                <text class="field"     x="14" y="170">created_at</text>
                <text class="field-type" x="186" y="170" text-anchor="end">TIMESTAMP</text>
              </g>

              <!-- ITEM -->
              <g transform="translate(550,90)">
                <rect class="entity" x="0" y="0" width="200" height="180" rx="10"/>
                <rect class="entity-head" x="0" y="0" width="200" height="36" rx="10"/>
                <rect class="entity-head" x="0" y="26" width="200" height="10"/>
                <text class="entity-title" x="100" y="23" text-anchor="middle">Item</text>

                <text class="key"       x="14" y="62">PK</text>
                <text class="field"     x="44" y="62">item_id</text>
                <text class="field-type" x="186" y="62" text-anchor="end">UUID</text>
                <line class="divider" x1="10" y1="74" x2="190" y2="74"/>

                <text class="key fk"    x="14" y="94">FK</text>
                <text class="field"     x="44" y="94">collection_id</text>
                <text class="field-type" x="186" y="94" text-anchor="end">UUID</text>

                <text class="field"     x="14" y="120">name</text>
                <text class="field-type" x="186" y="120" text-anchor="end">VARCHAR</text>

                <text class="field"     x="14" y="146">purchase_price</text>
                <text class="field-type" x="186" y="146" text-anchor="end">DECIMAL</text>

                <text class="field"     x="14" y="170">estimated_value</text>
                <text class="field-type" x="186" y="170" text-anchor="end">DECIMAL</text>
              </g>

              <!-- PRICE HISTORY -->
              <g transform="translate(810,90)">
                <rect class="entity" x="0" y="0" width="200" height="180" rx="10"/>
                <rect class="entity-head" x="0" y="0" width="200" height="36" rx="10"/>
                <rect class="entity-head" x="0" y="26" width="200" height="10"/>
                <text class="entity-title" x="100" y="23" text-anchor="middle">PriceHistory</text>

                <text class="key"       x="14" y="62">PK</text>
                <text class="field"     x="44" y="62">price_id</text>
                <text class="field-type" x="186" y="62" text-anchor="end">UUID</text>
                <line class="divider" x1="10" y1="74" x2="190" y2="74"/>

                <text class="key fk"    x="14" y="94">FK</text>
                <text class="field"     x="44" y="94">item_id</text>
                <text class="field-type" x="186" y="94" text-anchor="end">UUID</text>

                <text class="field"     x="14" y="120">recorded_at</text>
                <text class="field-type" x="186" y="120" text-anchor="end">TIMESTAMP</text>

                <text class="field"     x="14" y="146">value</text>
                <text class="field-type" x="186" y="146" text-anchor="end">DECIMAL</text>

                <text class="field"     x="14" y="170">source</text>
                <text class="field-type" x="186" y="170" text-anchor="end">VARCHAR</text>
              </g>

              <!-- Relationships -->
              <!-- User 1 ── M Collection -->
              <line class="rel-line" x1="230" y1="180" x2="290" y2="180" marker-start="url(#one)" marker-end="url(#many)"/>
              <text class="rel-label" x="260" y="172" text-anchor="middle">1 : M</text>

              <!-- Collection 1 ── M Item -->
              <line class="rel-line" x1="490" y1="180" x2="550" y2="180" marker-start="url(#one)" marker-end="url(#many)"/>
              <text class="rel-label" x="520" y="172" text-anchor="middle">1 : M</text>

              <!-- Item 1 ── M PriceHistory -->
              <line class="rel-line" x1="750" y1="180" x2="810" y2="180" marker-start="url(#one)" marker-end="url(#many)"/>
              <text class="rel-label" x="780" y="172" text-anchor="middle">1 : M</text>

              <!-- Legend -->
              <g transform="translate(30,310)">
                <circle cx="6" cy="6" r="5" fill="#C7A97A"/>
                <text class="field-type" x="20" y="10">PK &middot; Primary Key</text>
                <circle cx="150" cy="6" r="5" fill="#D98880"/>
                <text class="field-type" x="164" y="10">FK &middot; Foreign Key</text>
                <text class="field-type" x="300" y="10">Relationships shown as 1 : M (one-to-many)</text>
              </g>
            </svg>
          </div>
        </div>
      </div>

